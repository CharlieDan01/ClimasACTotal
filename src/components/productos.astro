---
// src/components/productos.astro

// Tu enlace de Google Sheets CSV
const SHEET_URL = 'https://docs.google.com/spreadsheets/d/e/2PACX-1vQjFlIqlgR9G13ldqNX5EevnC4LGNCBBmf30i7wRVLc69NjGmORr4gh6fPney9eZJwY1J58IaVrKhXK/pub?gid=0&single=true&output=csv';

let productos: any[] = [];

try {
    const response = await fetch(SHEET_URL);
    const csvText = await response.text();
    
    const lines = csvText.split('\n').map(line => line.trim()).filter(line => line.length > 0);
    if (lines.length > 1) {
        // Obtenemos los encabezados tal cual están en tu Excel (Product, Description, Price, img)
        const headers = lines[0].split(',');
        
        productos = lines.slice(1).map(line => {
            const values = line.split(',');
            const rowObject: { [key: string]: string } = {};
            headers.forEach((header, index) => {
                rowObject[header.trim()] = values[index] ? values[index].replace(/^"|"$/g, '').trim() : '';
            });
            return rowObject;
        });
    }
} catch (error) {
    console.error("Error al conectar con Google Sheets en el componente Productos:", error);
}
---

<section class="productos section-padding bg-light text-center" id="products">
    <div class="container">
        <h2 class="section-title">Nuestros Productos</h2>
        <p class="section-description">Equipos de climatización de alta eficiencia disponibles para instalación inmediata.</p>
        
        <div class="row g-4 mt-4 justify-content-center">
            {productos.length === 0 ? (
                <div class="col-12">
                    <p class="text-muted">Cargando catálogo de productos...</p>
                </div>
            ) : (
                productos.map((producto) => (
                    <div class="col-12 col-md-4 text-start">
                        <div class="card h-100 shadow-sm border-0 service-item" style="border-top: 4px solid var(--ac-blue); padding: 0; overflow: hidden;">
                            
                            {/* Imagen del producto: Ahora usa producto.img */}
                            <div class="product-img-wrapper" style="height: 220px; overflow: hidden; background-color: #ffffff; display: flex; align-items: center; justify-content: center; padding: 10px;">
                                <img 
                                    src={producto.img || '/img/ACclimaslogo.jpg'} 
                                    class="w-100 h-100" 
                                    style="object-fit: contain;" 
                                    alt={producto.Product} 
                                />
                            </div>
                            
                            {/* Cuerpo de la tarjeta */}
                            <div class="card-body p-4 d-flex flex-column justify-content-between">
                                <div>
                                    {/* Nombre del producto: Ahora usa producto.Product */}
                                    <h5 class="card-title fw-bold text-ac-blue mb-2" style="font-size: 1.2rem;">
                                        {producto.Product}
                                    </h5>
                                    {/* Descripción: Ahora usa producto.Description */}
                                    <p class="card-text text-muted small mb-3" style="line-height: 1.5;">
                                        {producto.Description}
                                    </p>
                                </div>
                                
                                <div>
                                    <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                                        <span class="text-muted small">Precio</span>
                                        {/* Precio: Ahora usa producto.Price */}
                                        <span class="fw-bold text-ac-red h5 mb-0">{producto.Price}</span>
                                    </div>
                                    <a href={`https://wa.me/14093549300?text=Hola,%20me%20interesa%20el%20producto:%20${encodeURIComponent(producto.Product)}`} target="_blank" class="btn btn-primary w-100 mt-3 fw-bold" style="background-color: var(--ac-blue); border: none;">
                                        <i class="bi bi-whatsapp me-2"></i>Cotizar Ahora
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                ))
            )}
        </div>
    </div>
</section>