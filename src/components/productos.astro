---
// src/components/productos.astro
---

<section class="productos section-padding bg-light text-center" id="products">
    <div class="container">
        <h2 class="section-title">Nuestros Productos</h2>
        <p class="section-description">Equipos de climatización de alta eficiencia.</p>
        
        <div id="productos-grid" class="row g-4 mt-4 justify-content-center">
            <div class="col-12">
                <p class="text-muted">Cargando catálogo...</p>
            </div>
        </div>
    </div>
</section>

<script>
    // PEGA AQUÍ TU ENLACE DE SHEETDB
    const SHEET_URL = 'https://sheetdb.io/api/v1/6lg1ixjc5u606'; 
    const grid = document.getElementById('productos-grid');

    async function cargarProductos() {
        try {
            const response = await fetch(SHEET_URL);
            const productos = await response.json(); // ¡Aquí está la magia del JSON!
            
            // Renderizado dinámico
            grid.innerHTML = productos.map((p, i) => `
                <div class="col-12 col-md-4 text-start">
                    <div class="card h-100 shadow-sm border-0 service-item" style="border-top: 4px solid var(--ac-blue);">
                        <div class="product-img-wrapper" style="height: 220px; overflow: hidden; display: flex; align-items: center; justify-content: center; padding: 10px;">
                            <img src="${p.img || '/img/aCclimaslogo.png'}" class="w-100 h-100" style="object-fit: contain;" alt="${p.Product}" />
                        </div>
                        <div class="card-body p-4 d-flex flex-column justify-content-between">
                            <h5 class="card-title fw-bold text-ac-blue mb-2">${p.Product}</h5>
                            <div>
                                <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                                    <span class="text-muted small">Precio</span>
                                    <span class="fw-bold text-ac-red h5 mb-0">${p.Price}</span>
                                </div>
                                <button type="button" class="btn btn-outline-dark w-100 mt-3 fw-bold" data-bs-toggle="modal" data-bs-target="#modal${i}">
                                    Mostrar más detalles
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal fade" id="modal${i}" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered modal-lg">
                        <div class="modal-content">
                            <div class="modal-header"><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                            <div class="modal-body p-4">
                                <div class="row align-items-center">
                                    <div class="col-md-5"><img src="${p.img || '/img/aCclimaslogo.png'}" class="img-fluid" /></div>
                                    <div class="col-md-7">
                                        <h3>${p.Product}</h3>
                                        <p class="text-muted">${p.Description}</p>
                                        <p class="fw-bold text-ac-red fs-4">${p.Price}</p>
                                        <a href="https://wa.me/14093549300?text=Me%20interesa:%20${encodeURIComponent(p.Product)}" class="btn btn-whatsapp-custom w-100">Solicitar Cotización</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('');
        } catch (e) {
            grid.innerHTML = '<p class="text-danger">Error al cargar productos.</p>';
        }
    }

    cargarProductos();
</script>